NUXT_PUBLIC_APP_NAME=Mashup Timer
NUXT_SPOTIFY_CLIENT_ID=
NUXT_SPOTIFY_CLIENT_SECRET=
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Local OAuth redirect URI. This must match the Spotify Dashboard exactly.
NUXT_SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback
NUXT_SPOTIFY_EXPORT_PLAYLIST_PUBLIC=false
